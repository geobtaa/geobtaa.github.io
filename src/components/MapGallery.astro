---
import FilterableGallery from './FilterableGallery.tsx';
import { isPublished, loadGalleryMaps } from '../utils/mapGallery';

const publishedMaps = (await loadGalleryMaps()).filter(isPublished);
---

<div class="map-gallery-container not-content">
  <p class="map-gallery-intro">A collection of interactive and static maps from the BTAA GIN Conference.</p>
  <p class="map-gallery-note">Note: The BTAA-GIN hosts this map gallery to highlight GIS projects happening across our member institutions and beyond. Static and interactive maps are provided "as is" based on information received from their authors and are not reviewed for quality or accuracy prior to inclusion in the gallery.</p>

  <FilterableGallery client:load maps={publishedMaps} previewDataUrl="/conference/map-gallery/preview.json" />
</div>

<style>
  .map-gallery-note {
    margin: 0 0 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--sl-color-accent);
    border-radius: 0.5rem;
    background-color: var(--sl-color-bg-alt);
    color: var(--sl-color-text);
  }

  .map-gallery-intro {
    font-size: 1.1rem; /* Slightly larger text */
    color: var(--sl-color-text);
    margin-bottom: 2rem; /* Adds space below the paragraph */
  }

  :global(.map-gallery-preview-note) {
    margin: 0 0 1rem;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--sl-color-orange-high);
    border-radius: 0.5rem;
    background-color: var(--sl-color-orange-low);
    color: var(--sl-color-text);
  }

/* Updated styles for the filter controls */
:global(.filter-controls) {
  display: flex; /* Aligns the label and select box in a row */
  align-items: center; /* Vertically centers the text with the select box */
  gap: 0.75rem; /* Adds space BETWEEN the label and the select box */
  margin-bottom: 2.5rem; /* Adds space below the entire filter control */
}

:global(.filter-controls label) {
  font-weight: 500;
}

:global(.filter-controls select) {
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  border: 1px solid var(--sl-color-hairline);
  background-color: var(--sl-color-bg);
}
  /* --- Grid & Card Styling --- */
  /* We use :global() so these styles can apply to the React component's output */

  :global(.gallery-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  :global(.project-card) {
    background-color: var(--sl-color-bg);
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  :global(.project-card:hover) {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.15);
  }

  :global(.card-image) {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  :global(.card-content) {
    padding: 1rem;
  }

  :global(.card-content h3) {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }
  
  :global(.card-content h4) {
    margin: 0;
    font-size: 0.9rem;
    color: #666;
    font-weight: normal;
  }

  /* --- Modal Styling --- */
  :global(.modal-backdrop) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    opacity: 0; /* Start invisible */
    pointer-events: none; /* Don't block clicks when invisible */
    transition: opacity .5s ease-out; /* Smooth transition for opacity over 0.3 seconds */
  }
  :global(.modal-backdrop[data-visible="true"]) {
    opacity: 1; /* Fully visible */
    pointer-events: auto; /* Allow clicks */
  }


  :global(.modal-content) {

    background-color: var(--sl-color-bg);
    color: var(--sl-color-text);
    padding: 2rem;
    border-radius: 8px;
    max-width: 800px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
  }

  :global(.modal-close) {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 4rem;
    cursor: pointer;
    color: #333;
  }

  :global(.modal-authors) {
    margin: 0 0 1.5rem;
    color: var(--sl-color-text);
    text-transform: none;
    letter-spacing: normal;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
  }

  :global(.modal-image) {
    width: min(42%, 320px);
    max-height: 420px;
    object-fit: contain;
    margin: 0 1rem 0.75rem 0;
    float: left;
  }

:global(.modal-link-card) {
  display: block;
  clear: both;
  margin-top: 1.5rem;
  padding: 1rem;
  border: 1px solid #8ec5ff;
  border-radius: 0.5rem;
  background-color: #e8f4ff;
  color: #0f4c81;
  text-decoration: none;
  transition: border-color 0.2s ease-out, background-color 0.2s ease-out;
}

:global(.modal-link-card:hover) {
  background-color: #d8ecff;
  border-color: #5ea7ea;
}

  @media (max-width: 640px) {
    :global(.modal-image) {
      width: 100%;
      max-height: 320px;
      margin: 0 0 1rem;
      float: none;
    }
  }
</style>
